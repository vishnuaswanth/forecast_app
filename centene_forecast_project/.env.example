# Copy this file to .env and fill in values before running.
# Never commit .env to source control.

# Generate a secret key (run one of these commands and paste the output below):
#   Python : python -c "import secrets; print(secrets.token_urlsafe(64))"
#   PowerShell: -join ((65..90)+(97..122)+(48..57) | Get-Random -Count 64 | % {[char]$_})
CENTENE_SECRET_KEY=your-secret-key-here
CENTENE_DEBUG=True
CENTENE_ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated list of trusted HTTPS origins for CSRF (required in production)
# Example: CENTENE_CSRF_TRUSTED_ORIGINS=https://your-server.company.com
CENTENE_CSRF_TRUSTED_ORIGINS=

CENTENE_OPENAI_API_KEY=

# LLM provider selection: 'openai' (default) or 'azure_openai'
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Azure OpenAI (only required when LLM_PROVIDER=azure_openai)
# AZURE_OPENAI_DEPLOYMENT is the *deployment name* you set in Azure OpenAI
# Studio when deploying the model — not the underlying model name.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_API_KEY=

CENTENE_API_BASE_URL=http://127.0.0.1:8888
CENTENE_PBIRS_CLAIMS_CAPACITY_URL=http://10.111.36.98/reports/powerbi/COMMERCIAL/Centene/Claims%20Capacity%20Planning%20Dashboard?rs:Embed=true
