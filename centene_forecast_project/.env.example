# Copy this file to .env and fill in values before running.
# Never commit .env to source control.

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated list of trusted HTTPS origins for CSRF (required in production)
# Example: CSRF_TRUSTED_ORIGINS=https://your-server.company.com
CSRF_TRUSTED_ORIGINS=

# HTTPS security overrides — useful when testing DEBUG=False locally over plain HTTP
# In production these default to True automatically; set False only for local testing
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

OPENAI_API_KEY=

API_BASE_URL=http://127.0.0.1:8888
PBIRS_CLAIMS_CAPACITY_URL=http://10.111.36.98/reports/powerbi/COMMERCIAL/Centene/Claims%20Capacity%20Planning%20Dashboard?rs:Embed=true
