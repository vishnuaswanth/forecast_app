    %% Relationships

    forecastmodel ||--o{ ramp_model : "forecast_id → id (one forecast row can have many ramp weeks)"

    allocationexecutionmodel ||--o{ allocationreportsmodel : "execution_id → execution_id (one run generates 3 report types)"

    allocationexecutionmodel ||--o{ fte_allocation_mapping : "execution_id → allocation_execution_id (one run maps many FTEs)"

    allocationexecutionmodel ||--o| allocation_validity : "execution_id → allocation_execution_id (tracks if this run is still valid)"

    history_log ||--o{ history_change : "history_log_id → history_log_id (one log entry has many field changes)"

    rostertemplate ||--o{ fte_allocation_mapping : "CN → cn (employee identity links roster to allocation)"

    target_cph_configuration }o--|| forecastmodel : "MainLOB+CaseType → Main_LOB+Case_Type (logical: CPH config drives forecast calculations)"

    monthconfigurationmodel }o--|| forecastmodel : "Month+Year+WorkType → Month+Year+WorkType (logical: config drives FTE and Capacity values)"
